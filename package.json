{
  "name": "@triminds/ui-core",
  "version": "1.0.0",
  "description": "Triminds Platform UI - React Design System and UI Component Library.",

  "type": "module",

  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },

  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],

  "sideEffects": [
    "**/*.css"
  ],

  "keywords": [
    "triminds",
    "react",
    "design-system",
    "ui",
    "components",
    "tailwindcss",
    "typescript",
    "vite"
  ],

  "homepage": "https://github.com/RodrigoDiasDeOliveira/Triminds-PlatformUI",

  "bugs": {
    "url": "https://github.com/RodrigoDiasDeOliveira/Triminds-PlatformUI/issues"
  },

  "repository": {
    "type": "git",
    "url": "git+https://github.com/RodrigoDiasDeOliveira/Triminds-PlatformUI.git"
  },

  "license": "MIT",

  "engines": {
    "node": ">=20"
  },

  "packageManager": "pnpm@9.0.0",

  "scripts": {
    "dev": "vite",

    "build": "vite build",

    "preview": "vite preview",

    "typecheck": "tsc --noEmit",

    "lint": "eslint src --ext .ts,.tsx",

    "test": "vitest run",

    "test:watch": "vitest",

    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\""
  },

  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },

  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",

    "@vitejs/plugin-react": "^4.3.0",

    "typescript": "^5.5.0",

    "vite": "^5.4.0",

    "vite-plugin-dts": "^4.2.0",

    "vitest": "^2.0.0"
  },

  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}