{
  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "isolatedModules": true,
    "resolveJsonModule": true,

    "noEmit": true,

    "baseUrl": ".",

    "paths": {
      "@/*": [
        "src/*"
      ]
    },

    "types": [
      "node",
      "vitest/globals"
    ],

    "ignoreDeprecations": "6.0"
  },

  "include": [
    "src",
    "tests",
    "stories",
    "vite.config.ts",
    "vitest.config.ts"
  ],

  "exclude": [
    "dist",
    "node_modules",
    "coverage"
  ]
}