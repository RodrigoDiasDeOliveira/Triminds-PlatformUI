{
  "extends": "./tsconfig.json",

  "compilerOptions": {
    "noEmit": false,

    "declaration": true,
    "declarationMap": true,

    "emitDeclarationOnly": true,

    "declarationDir": "dist",

    "rootDir": "src",

    "stripInternal": true
  },

  "include": [
    "src"
  ],

  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.tsx",
    "tests",
    "stories"
  ]
}