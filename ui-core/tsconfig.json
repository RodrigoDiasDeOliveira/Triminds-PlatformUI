{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,

    "declaration": true,

    "declarationMap": true,

    "sourceMap": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "noEmit": true,

  

    "paths": {
      "@/*": [
        "./src/*"
      ]
    },

    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ]
  },

  "include": [
    "src",
    "tests"
  ]
}